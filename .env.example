# PostgreSQL connection string
DATABASE_URL=

# Secret key for signing JWT tokens (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=

# JWT token expiry in minutes
JWT_EXPIRE_MINUTES=60

# Redis connection URL (for Celery broker and result backend)
REDIS_URL=redis://localhost:6379/0

# Celery scheduler interval in seconds (how often to poll for new dividends)
DRIP_POLL_INTERVAL_SECONDS=300

# Alpaca API base URL (use paper trading URL for development)
# Paper: https://paper-api.alpaca.markets
# Live:  https://api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Encryption key for storing user Alpaca API keys at rest (generate with: openssl rand -hex 32)
CREDENTIAL_ENCRYPTION_KEY=

# Frontend public URL (used for CORS)
FRONTEND_URL=http://localhost:3000
